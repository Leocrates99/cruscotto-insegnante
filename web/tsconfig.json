{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "noUnusedLocals": false,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@model": ["src/model/index.ts"],
      "@root-src/*": ["../src/*"],
      "@root-config/*": ["../config/*"]
    }
  },
  "include": ["src", "vite.config.ts"]
}
